{
  "name": "oneshot-dlg-language",
  "displayName": "OneShot Dialogue (.dlg)",
  "description": "Language support for EyeDaleHim's OneShot dialogue script files (.dlg).",
  "version": "0.0.1",
  "publisher": "EyeDaleHim",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EyeDaleHim/OneShot-Dialog.git"
  },
  "icon": "icon.png",
  "keywords": [
    "oneshot",
    "dialogue",
    "dlg"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dlg",
        "aliases": [
          "OneShot Dialogue",
          "dlg"
        ],
        "extensions": [
          ".dlg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dlg",
        "scopeName": "source.dlg",
        "path": "./syntaxes/dlg.tmLanguage.json"
      }
    ]
  }
}
