{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OneShot Dialogue (Strict)",
  "scopeName": "source.dlg",
  "patterns": [
    { "include": "#comments" },
    { "include": "#sceneHeader" },
    { "include": "#blockKeywords" },
    { "include": "#statementKeywords" },
    { "include": "#optionKeyword" },
    { "include": "#namedArgsNumeric" },
    { "include": "#namedArgsString" },
    { "include": "#namedArgColor" },
    { "include": "#namedArgEnum" },
    { "include": "#namedArgBoolean" },
    { "include": "#invalidTypes" },
    { "include": "#conditionals" },
    { "include": "#values" },
    { "include": "#inlineOverrides" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.dlg",
          "match": "#(?!([0-9A-Fa-f]{6}\\b)).*$"
        }
      ]
    },
    "sceneHeader": {
      "patterns": [
        {
          "name": "meta.scene.header.dlg",
          "match": "^(\\s*)(scene)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(\\s*:)",
          "captures": {
            "2": { "name": "keyword.control.scene.dlg" },
            "4": { "name": "entity.name.section.scene.dlg" },
            "5": { "name": "punctuation.separator.colon.dlg" }
          }
        }
      ]
    },
    "blockKeywords": {
      "patterns": [
        {
          "name": "keyword.control.block.dlg",
          "match": "^(\\s*)(params|choice|else)(\\s*:)",
          "captures": {
            "2": { "name": "keyword.control.dlg" },
            "3": { "name": "punctuation.separator.colon.dlg" }
          }
        },
        {
          "name": "meta.if.statement.dlg",
          "match": "^(\\s*)(if)\\b(.*?)(:)\\s*$",
          "captures": {
            "2": { "name": "keyword.control.conditional.dlg" },
            "3": { "name": "meta.condition.dlg" },
            "4": { "name": "punctuation.separator.colon.dlg" }
          }
        }
      ]
    },
    "statementKeywords": {
      "patterns": [
        {
          "name": "keyword.control.statement.dlg",
          "match": "^(\\s*)(say|script|freeze|voice_blip|goto)\\b"
        }
      ]
    },
    "optionKeyword": {
      "patterns": [
        {
          "name": "meta.choice.option.dlg",
          "match": "^(\\s*)(option)\\b",
          "captures": {
            "2": { "name": "keyword.control.option.dlg" }
          }
        }
      ]
    },
    "namedArgsNumeric": {
      "patterns": [
        {
          "name": "variable.parameter.argument.numeric.dlg",
          "match": "\\bspeed\\b(?=\\s*=)"
        }
      ]
    },
    "namedArgsString": {
      "patterns": [
        {
          "name": "variable.parameter.argument.string.dlg",
          "match": "\\b(actor|portrait|voice|sound)\\b(?=\\s*=)"
        }
      ]
    },
    "namedArgColor": {
      "patterns": [
        {
          "name": "variable.parameter.argument.color.dlg",
          "match": "\\bcolor\\b(?=\\s*=)"
        }
      ]
    },
    "namedArgEnum": {
      "patterns": [
        {
          "name": "variable.parameter.argument.enum.dlg",
          "match": "\\b(effect|position|blipStyle|style)\\b(?=\\s*=)"
        }
      ]
    },
    "namedArgBoolean": {
      "patterns": [
        {
          "name": "variable.parameter.argument.boolean.dlg",
          "match": "\\bforce\\b(?=\\s*=)"
        }
      ]
    },
    "invalidTypes": {
      "patterns": [
        {
          "comment": "Numeric arg (speed) assigned a quoted string",
          "name": "invalid.illegal.type.expected-numeric.got-string.dlg",
          "match": "(?<=\\bspeed\\s*=\\s*)\"[^\"]*\""
        },
        {
          "comment": "Numeric arg (speed) assigned an unquoted identifier",
          "name": "invalid.illegal.type.expected-numeric.got-identifier.dlg",
          "match": "(?<=\\bspeed\\s*=\\s*)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "comment": "String args (actor, portrait, voice, sound) assigned a bare number",
          "name": "invalid.illegal.type.expected-string.got-number.dlg",
          "match": "(?<=\\b(actor|portrait|voice|sound)\\s*=\\s*)\\d+\\.?\\d*"
        },
        {
          "comment": "position must be top, bottom, or center",
          "name": "invalid.illegal.type.expected-position-value.dlg",
          "match": "(?<=\\bposition\\s*=\\s*)(?!(top|bottom|center)\\b)(\\d+\\.?\\d*|[A-Za-z_][A-Za-z0-9_]*|\"[^\"]*\")"
        },
        {
          "comment": "effect must be none, shake, wave, flicker, or rainbow",
          "name": "invalid.illegal.type.expected-effect-value.dlg",
          "match": "(?<=\\beffect\\s*=\\s*)(?!(none|shake|wave|flicker|rainbow)\\b)(\\d+\\.?\\d*|[A-Za-z_][A-Za-z0-9_]*|\"[^\"]*\")"
        },
        {
          "comment": "blipStyle/style must be monophonic, polyphonic, or solophonic",
          "name": "invalid.illegal.type.expected-blipstyle-value.dlg",
          "match": "(?<=\\b(blipStyle|style)\\s*=\\s*)(?!(monophonic|polyphonic|solophonic)\\b)(\\d+\\.?\\d*|[A-Za-z_][A-Za-z0-9_]*|\"[^\"]*\")"
        },
        {
          "comment": "force must be true or false",
          "name": "invalid.illegal.type.expected-boolean-value.dlg",
          "match": "(?<=\\bforce\\s*=\\s*)(?!(true|false)\\b)(\\d+\\.?\\d*|[A-Za-z_][A-Za-z0-9_]*|\"[^\"]*\")"
        },
        {
          "comment": "color must be #RRGGBB or none",
          "name": "invalid.illegal.type.expected-color.dlg",
          "match": "(?<=\\bcolor\\s*=\\s*)(?!#[0-9A-Fa-f]{6}\\b|none\\b)(\\d+\\.?\\d*|[A-Za-z_][A-Za-z0-9_]*|\"[^\"]*\")"
        },
        {
          "comment": "Inline: speed/delay must be numeric",
          "name": "invalid.illegal.type.inline.expected-numeric.dlg",
          "match": "(?<=\\{[^}]*\\b(speed|delay)\\s*=\\s*)(\"[^\"]*\"|[A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "comment": "Inline: color must be #RRGGBB or none",
          "name": "invalid.illegal.type.inline.expected-color.dlg",
          "match": "(?<=\\{[^}]*\\bcolor\\s*=\\s*)(?!#[0-9A-Fa-f]{6}\\b|none\\b)(\\d+\\.?\\d*|[A-Za-z_][A-Za-z0-9_]*|\"[^\"]*\")"
        }
      ]
    },
    "conditionals": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.dlg",
          "match": "==|!="
        },
        {
          "name": "keyword.control.conditional.inline.dlg",
          "match": "\\bif\\b"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.numeric.float.dlg",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.dlg",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.language.boolean.dlg",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.other.color.hex.dlg",
          "match": "#[0-9A-Fa-f]{6}\\b"
        },
        {
          "name": "constant.language.none.dlg",
          "match": "\\bnone\\b"
        }
      ]
    },
    "inlineOverrides": {
      "patterns": [
        {
          "name": "meta.inline.override.dlg",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.braces.begin.dlg" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.dlg" }
          },
          "patterns": [
            {
              "name": "variable.parameter.inline.dlg",
              "match": "\\b(color|effect|speed|delay)\\b"
            },
            {
              "name": "keyword.operator.assignment.dlg",
              "match": "="
            },
            { "include": "#values" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dlg",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.dlg",
              "match": "\\\\."
            },
            { "include": "#inlineOverrides" }
          ]
        }
      ]
    }
  }
}